{
  "name": "wdi5-test-project",
  "version": "1.0.0",
  "description": "UI5 Automation Tests – WDI5 + OPA5 + UiVeri5",

  "scripts": {
    "test:opa5"       : "node scripts/run-opa5.js",
    "test:wdi5"       : "wdio run ./wdio.conf.js",
    "test:wdi5:cov"   : "nyc --reporter=lcov --reporter=text --report-dir=coverage wdio run ./wdio.conf.js",
    "test:uiveri5"    : "uiveri5 --config webapp/test/e2e/conf.js",

    "ci-all"          : "npm run test:wdi5 && npm run test:opa5"
  },

  "nyc": {
    "include": ["webapp/**/*.js"],
    "exclude": ["webapp/test/**", "**/node_modules/**"],
    "reporter": ["lcov", "text", "json-summary"],
    "report-dir": "coverage",
    "all": true
  },

  "devDependencies": {
    "@wdio/cli": "^8.8.1",
    "@wdio/local-runner": "^8.8.1",
    "@wdio/spec-reporter": "^8.8.1",
    "@wdio/junit-reporter": "^8.8.1",
    "@wdio/json-reporter": "^8.8.1",
    "@wdio/mocha-framework": "^8.8.1",
    "wdio-ui5-service": "^2.2.1",
    "nyc": "^15.1.0",
    "grunt": "^1.6.1",
    "grunt-cli": "^1.4.3"
  },

  "dependencies": {
    "selenium-webdriver": "^4.15.0"
  },

  "engines": {
    "node": ">=20"
  }
}