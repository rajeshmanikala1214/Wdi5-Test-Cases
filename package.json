{
  "name": "wdi5-test-project",
  "version": "1.0.0",
  "description": "UI5 Automation Tests – WDI5 + OPA5 + UiVeri5",
  "scripts": {
    "test:opa5": "node scripts/run-opa5.js",
    "test:wdi5": "wdio run ./wdio.conf.js",
    "test:wdi5:cov:ci": "npx serve -s . -l 8080 & SERVER_PID=$! && sleep 3 && nyc --reporter=lcov --reporter=text --report-dir=coverage wdio run ./wdio.conf.js; EXIT=$?; kill $SERVER_PID 2>/dev/null; exit $EXIT",
    "test:uiveri5": "uiveri5 --config webapp/test/ui5-uiveri5/conf.js",
    "ci-all": "npm run test:wdi5 && npm run test:opa5",
    "build": "ui5 build"
  },
  "nyc": {
    "include": [
      "webapp/**/*.js"
    ],
    "exclude": [
      "webapp/test/**",
      "**/node_modules/**"
    ],
    "reporter": [
      "lcov",
      "text",
      "json-summary"
    ],
    "report-dir": "coverage",
    "all": true
  },
  "devDependencies": {
    "@wdio/cli": "^8.8.1",
    "@wdio/json-reporter": "^8.8.1",
    "@wdio/junit-reporter": "^8.8.1",
    "@wdio/local-runner": "^8.8.1",
    "@wdio/mocha-framework": "^8.8.1",
    "@wdio/spec-reporter": "^8.8.1",
    "grunt": "^1.6.1",
    "grunt-cli": "^1.4.3",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-junit-reporter": "^2.0.1",
    "karma-ui5": "^4.1.0",
    "nyc": "^15.1.0",
    "wdio-ui5-service": "^2.2.1"
  },
  "dependencies": {
    "selenium-webdriver": "^4.15.0"
  },
  "engines": {
    "node": ">=20"
  }
}
