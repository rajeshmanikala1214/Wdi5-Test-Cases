{
  "name": "wdi5-test-project",
  "version": "1.0.0",
  "description": "WDI5 UI5 Automation Tests",
  
  "scripts": {
    "test:opa5": "npx ui5 serve --port 8080 & sleep 15 && npx ui5-test-runner --url http://localhost:8080/test/testsuite.qunit.html --report-dir reports --coverage",
    "wdi5": "wdio run webapp/test/e2e/wdio.conf.js"
  },

  "devDependencies": {
