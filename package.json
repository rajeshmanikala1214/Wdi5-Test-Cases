{
  "name": "wdi5-test-project",
  "version": "1.0.0",
  "description": "UI5 Automation Tests – WDI5 + OPA5 + UiVeri5",

  "scripts": {
    "wdi5"   : "wdio run ./wdio.conf.js",
    "opa5"   : "node scripts/run-opa5.js",
    "ci-e2e" : "npm run wdi5",
    "ci-all" : "npm run wdi5 && npm run opa5",
    "test:coverage": "nyc --reporter=lcov --reporter=text npm run wdi5"
  },

  "devDependencies": {
    "@wdio/cli"            : "^8.8.1",
    "@wdio/local-runner"   : "^8.8.1",
    "@wdio/spec-reporter"  : "^8.8.1",
    "@wdio/junit-reporter" : "^8.8.1",
    "@wdio/json-reporter"  : "^8.8.1",
    "@wdio/mocha-framework": "^8.8.1",
    "wdio-ui5-service"     : "^2.2.1",
    "typescript"           : "^5.2.2"
  },

  "dependencies": {
    "selenium-webdriver": "^4.15.0"
  },

  "engines": {
    "node": ">=20.0.0"
  }
}